# Unity generated. All of this is rebuilt from Assets/ + ProjectSettings/ +
# Packages/, so committing it only adds hundreds of megabytes of churn.
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Solution and project files are regenerated by the editor on demand.
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

/.vscode/
/.idea/
*.apk
*.aab
*.unitypackage
*.app

# Crash reports
sysinfo.txt
crashlytics-build.properties

# Generated by the com.arsmi.gamehub package on load (Editor/ArsmiTemplateInstaller.cs).
# Unity only reads WebGL templates from Assets/, so this is a copy of the one in the
# package. The package is the source of truth; do not edit this one, it gets overwritten.
/[Aa]ssets/WebGLTemplates/ArsmiGames/
/[Aa]ssets/WebGLTemplates/ArsmiGames.meta
/[Aa]ssets/WebGLTemplates.meta

# Imported package samples belong to whoever imported them, not to the SDK repo.
/[Aa]ssets/Samples/
/[Aa]ssets/Samples.meta
